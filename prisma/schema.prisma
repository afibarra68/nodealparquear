// Esquema mínimo: alinear modelos con Flyway (parking-app) o usar `prisma db pull` contra la BD existente.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Credenciales de login. Ajustá @@map y @map con `npx prisma db pull` si tu tabla/columnas vienen de Flyway (parking-app).
model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String @map("password")

  @@map("users")
}
