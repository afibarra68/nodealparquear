# Copiar a .env. Si el puerto 3000 está ocupado (p. ej. Grafana en Docker), usá otro:
# PORT=4001

DATABASE_URL="postgresql://admin:telodijecomma@localhost:5432/appdb?schema=public"
# Opcional: solo para `docker compose` servicio `api`. Misma base/usuario; host = host.docker.internal si Postgres corre en tu máquina.
DATABASE_URL_DOCKER="postgresql://admin:telodijecomma@host.docker.internal:5432/appdb?schema=public"
NODE_ENV=development
PORT=4001
